# Multi-provider setup with automatic fallback. The app tries these in order
# — Groq, Gemini, NVIDIA, then Ollama (local) — and moves to the next one
# automatically if a provider is rate-limited or out of credits.
#
# You DON'T need all of these. Fill in whichever free keys you have; leave
# the rest blank/commented and they'll just be skipped. Ollama alone
# (no keys at all) also works fine on its own.

# Groq — fast, generous free tier. Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini — Google AI Studio. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA NIM API catalog (cloud, not self-hosted). Get a key: https://build.nvidia.com
# Model slugs in NVIDIA's catalog change over time — double check yours there.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Ollama — local, no key needed, no limit. Always used as the final fallback.
# Install: https://ollama.com/download   then:  ollama pull qwen2.5:3b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

PORT=3000
